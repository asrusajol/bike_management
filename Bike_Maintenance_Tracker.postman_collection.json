    {
      "name": "Stats",
      "description": "Returns aggregated statistics for a bike.\n\nResponse shape (BikeStats):\n  summary:\n    total_fuel_cost, total_service_cost, total_expense_cost, total_cost\n    fuel_logs_count, service_logs_count, expense_count\n    total_km_run, daily_avg_km, days_tracked\n    fuel_daily_avg_cost, fuel_min_efficiency, fuel_max_efficiency  (km/L)\n  monthly: [{month, fuel_cost, service_cost, expense_cost, total_cost}]\n  avg_fuel_efficiency  (km/L, full-tank fills only)\n  cost_per_km\n  expense_by_category: [{category, cost}]",
